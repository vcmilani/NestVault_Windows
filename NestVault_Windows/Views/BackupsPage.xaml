<Page
    x:Class="NestVault_Windows.Views.BackupsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dataGrid="using:CommunityToolkit.WinUI.Controls"
    xmlns:models="using:NestVault_Windows.Models"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="140" MaxWidth="320" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="260" MinWidth="180" MaxWidth="400" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Column 1: Backup List -->
        <Grid Grid.Column="0" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="8 8 8 4" Spacing="6">
                <TextBlock Text="Backups"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Padding="4 0" />
                <TextBox PlaceholderText="Search..."
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         CornerRadius="4" />
            </StackPanel>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.FilteredBackups, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedBackup, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:BackupSummary">
                        <StackPanel Padding="4 6" Spacing="2">
                            <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind FormattedSize}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Rectangle Grid.Column="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Column 2: Versions -->
        <Grid Grid.Column="2" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Versions"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Padding="12 12 12 8" />

            <ProgressRing Grid.Row="1"
                          IsActive="{x:Bind ViewModel.IsLoadingVersions, Mode=OneWay}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Visibility="{x:Bind ViewModel.IsLoadingVersions, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Versions, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedVersion, Mode=TwoWay}"
                      SelectionMode="Single"
                      Visibility="{x:Bind ViewModel.IsLoadingVersions, Mode=OneWay, Converter={StaticResource BoolNegToVisConverter}}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:BackupVersion">
                        <Grid Padding="8 6" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{x:Bind VersionKey}"
                                           FontSize="12" FontFamily="Consolas"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Status}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind FormattedSize}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Delete Version"
                                        Command="{x:Bind ViewModel.DeleteVersionCommand}"
                                        CommandParameter="{x:Bind ViewModel.SelectedVersion, Mode=OneWay}">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE74D;" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </ListView.ContextFlyout>
            </ListView>
        </Grid>

        <Rectangle Grid.Column="3" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Column 3: Files -->
        <Grid Grid.Column="4" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Files"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Padding="12 12 12 8" />

            <ProgressRing Grid.Row="1"
                          IsActive="{x:Bind ViewModel.IsLoadingFiles, Mode=OneWay}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Visibility="{x:Bind ViewModel.IsLoadingFiles, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />

            <dataGrid:DataGrid Grid.Row="1"
                               ItemsSource="{x:Bind ViewModel.Files, Mode=OneWay}"
                               AutoGenerateColumns="False"
                               IsReadOnly="True"
                               GridLinesVisibility="Horizontal"
                               HeadersVisibility="Column"
                               Visibility="{x:Bind ViewModel.IsLoadingFiles, Mode=OneWay, Converter={StaticResource BoolNegToVisConverter}}">
                <dataGrid:DataGrid.Columns>
                    <dataGrid:DataGridTextColumn Header="Path"
                                                 Binding="{Binding OriginalPath}"
                                                 Width="*" />
                    <dataGrid:DataGridTextColumn Header="Size"
                                                 Binding="{Binding FormattedSize}"
                                                 Width="80" />
                    <dataGrid:DataGridTextColumn Header="SHA-256"
                                                 Binding="{Binding Sha256}"
                                                 Width="120"
                                                 FontFamily="Consolas" />
                </dataGrid:DataGrid.Columns>
            </dataGrid:DataGrid>
        </Grid>
    </Grid>
</Page>
