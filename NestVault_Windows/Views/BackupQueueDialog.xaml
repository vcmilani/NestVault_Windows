<ContentDialog
    x:Class="NestVault_Windows.Views.BackupQueueDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:NestVault_Windows.Services"
    xmlns:models="using:NestVault_Windows.Models"
    Title="Backup Queue"
    PrimaryButtonText="Close"
    IsPrimaryButtonEnabled="{x:Bind ViewModel.IsFinished, Mode=OneWay}"
    DefaultButton="Primary"
    MinWidth="520"
    MaxWidth="700">

    <StackPanel Spacing="16" MinHeight="380">

        <!-- Select profiles -->
        <StackPanel Spacing="8"
                    Visibility="{x:Bind ViewModel.IsIdle, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
            <TextBlock Text="Select profiles to run:" Style="{StaticResource SubtitleTextBlockStyle}" />
            <ListView ItemsSource="{x:Bind ViewModel.AllProfiles, Mode=OneWay}"
                      SelectionMode="Multiple"
                      MaxHeight="200"
                      SelectionChanged="ProfileList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:BackupProfile">
                        <StackPanel Padding="4 4" Spacing="2">
                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind Label}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Button Content="Start Queue"
                    Style="{StaticResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.StartQueueCommand}"
                    IsEnabled="{x:Bind ViewModel.CanStart, Mode=OneWay}" />
        </StackPanel>

        <!-- Queue progress -->
        <StackPanel Spacing="12"
                    Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
            <ProgressBar Value="{x:Bind ViewModel.Progress, Mode=OneWay}" Maximum="1.0" />

            <ListView ItemsSource="{x:Bind ViewModel.QueueItems, Mode=OneWay}"
                      SelectionMode="None"
                      MaxHeight="260">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="svc:BackupQueue+QueueItem">
                        <Grid Padding="4 6" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind StatusIcon}"
                                       FontSize="16" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{x:Bind Profile.Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Profile.Label}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Content="Cancel Queue"
                    HorizontalAlignment="Right"
                    Command="{x:Bind ViewModel.CancelQueueCommand}"
                    IsEnabled="{x:Bind ViewModel.CanCancel, Mode=OneWay}" />
        </StackPanel>

    </StackPanel>
</ContentDialog>
