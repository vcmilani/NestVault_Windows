<ContentDialog
    x:Class="NestVault_Windows.Views.BackupRunnerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:NestVault_Windows.Services"
    Title="{x:Bind DialogTitle}"
    PrimaryButtonText="Close"
    IsPrimaryButtonEnabled="{x:Bind ViewModel.IsFinished, Mode=OneWay}"
    DefaultButton="Primary"
    MinWidth="600"
    MaxWidth="800">

    <StackPanel Spacing="16" MinHeight="420">

        <!-- Progress bar -->
        <ProgressBar Value="{x:Bind ViewModel.Progress, Mode=OneWay}"
                     Maximum="1.0" />

        <!-- Stats row -->
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition /><ColumnDefinition />
                <ColumnDefinition /><ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.Stats.Uploaded, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="uploaded" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.Stats.Registered, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="registered" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.Stats.Cached, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="cached" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.Stats.Ignored, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="ignored" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                <TextBlock Text="{x:Bind ViewModel.Stats.Errors, Mode=OneWay}"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{x:Bind ViewModel.HasErrors, Mode=OneWay, Converter={StaticResource BoolToRedConverter}}" />
                <TextBlock Text="errors" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- Current file -->
        <TextBlock Text="{x:Bind ViewModel.CurrentFile, Mode=OneWay}"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextTrimming="CharacterEllipsis" />

        <!-- Log -->
        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="4" Height="240">
            <ScrollViewer x:Name="LogScroller" Padding="8">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="svc:BackupRunner+LogEntry">
                            <TextBlock Text="{x:Bind Text}"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{x:Bind Kind, Converter={StaticResource LogKindToColorConverter}}"
                                       TextWrapping="WrapWholeWords" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Cancel button -->
        <Button Content="Cancel Backup"
                HorizontalAlignment="Right"
                Command="{x:Bind ViewModel.CancelCommand}"
                IsEnabled="{x:Bind ViewModel.CanCancel, Mode=OneWay}" />

    </StackPanel>
</ContentDialog>
