<Application
    x:Class="NestVaultWindows.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Views/AppResources.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- System tray icon -->
            <tb:TaskbarIcon x:Key="TrayIcon"
                            ToolTipText="NestVault"
                            IconSource="Assets/tray.ico">
                <tb:TaskbarIcon.ContextMenuMode>SecondWindow</tb:TaskbarIcon.ContextMenuMode>
                <tb:TaskbarIcon.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="TrayOpenItem"  Text="Open NestVault" />
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="TrayQuitItem"  Text="Quit" />
                    </MenuFlyout>
                </tb:TaskbarIcon.ContextFlyout>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>
