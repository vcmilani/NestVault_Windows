<Page
    x:Class="NestVaultWindows.Views.BackupConfigsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:NestVaultWindows.Models"
    Background="Transparent">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="160" MaxWidth="340" />
            <ColumnDefinition Width="4" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left panel: profile list -->
        <Grid Grid.Column="0" RowSpacing="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="My Backups"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Padding="12 12 12 8" />

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.Profiles, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                      SelectionMode="Single">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:BackupProfile">
                        <Grid Padding="4 6" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Ellipse Grid.Column="0" Width="8" Height="8"
                                     VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{x:Bind Enabled, Converter={StaticResource BoolToGreenRedConverter}}" />
                                </Ellipse.Fill>
                            </Ellipse>
                            <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind Label}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Toolbar -->
            <CommandBar Grid.Row="2" DefaultLabelPosition="Collapsed"
                        Background="Transparent" OverflowButtonVisibility="Collapsed">
                <AppBarButton Icon="Add" Label="Add"
                              Command="{x:Bind ViewModel.AddProfileCommand}" />
                <AppBarButton Icon="Delete" Label="Delete"
                              Command="{x:Bind ViewModel.DeleteProfileCommand}"
                              CommandParameter="{x:Bind ViewModel.SelectedProfile, Mode=OneWay}"
                              IsEnabled="{x:Bind ViewModel.IsEditing, Mode=OneWay}" />
                <AppBarSeparator />
                <AppBarButton Icon="Play" Label="Run"
                              Click="RunBackup_Click"
                              IsEnabled="{x:Bind ViewModel.IsEditing, Mode=OneWay}" />
                <AppBarButton Icon="List" Label="Queue"
                              Click="RunQueue_Click" />
            </CommandBar>
        </Grid>

        <Rectangle Grid.Column="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Right panel: editor -->
        <ScrollViewer Grid.Column="2"
                      Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel Padding="20" Spacing="16">

                <!-- Save/discard bar -->
                <Grid Visibility="{x:Bind ViewModel.IsDirty, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                    <InfoBar Title="Unsaved changes"
                             Severity="Informational"
                             IsOpen="True"
                             IsClosable="False">
                        <InfoBar.ActionButton>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Save" Style="{StaticResource AccentButtonStyle}"
                                        Command="{x:Bind ViewModel.SaveProfileCommand}" />
                                <Button Content="Discard"
                                        Command="{x:Bind ViewModel.DiscardChangesCommand}" />
                            </StackPanel>
                        </InfoBar.ActionButton>
                    </InfoBar>
                </Grid>

                <TabView x:Name="EditorTabs" TabWidthMode="Equal" IsAddTabButtonVisible="False">

                    <!-- General tab -->
                    <TabViewItem Header="General">
                        <ScrollViewer Padding="0 12">
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Profile name" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBox Text="{x:Bind ViewModel.EditingProfile.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="e.g. Home Documents" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Backup label" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBox Text="{x:Bind ViewModel.EditingProfile.Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="e.g. home-docs (no spaces)" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Source folder" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{x:Bind ViewModel.EditingProfile.SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PlaceholderText="C:\Users\..." />
                                        <Button Grid.Column="1" Content="Browse..."
                                                Click="BrowseFolder_Click" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Workers" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <NumberBox Value="{x:Bind ViewModel.EditingProfile.Workers, Mode=TwoWay}"
                                               Minimum="1" Maximum="32" SpinButtonPlacementMode="Compact" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Prefix" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBox Text="{x:Bind ViewModel.EditingProfile.Prefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Optional path prefix on server" />
                                </StackPanel>
                                <ToggleSwitch Header="Enabled" IsOn="{x:Bind ViewModel.EditingProfile.Enabled, Mode=TwoWay}" />
                                <ToggleSwitch Header="Smart Skip" IsOn="{x:Bind ViewModel.EditingProfile.SmartSkip, Mode=TwoWay}" />
                                <ToggleSwitch Header="Accumulate (absorb previous version)" IsOn="{x:Bind ViewModel.EditingProfile.Accumulate, Mode=TwoWay}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>

                    <!-- Server tab -->
                    <TabViewItem Header="Server">
                        <ScrollViewer Padding="0 12">
                            <StackPanel Spacing="12">
                                <InfoBar Title="Server Override"
                                         Message="Leave empty to use the global server URL from Settings."
                                         Severity="Informational"
                                         IsOpen="True" IsClosable="False" />
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Server URL (override)" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBox Text="{x:Bind ViewModel.EditingProfile.ServerOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="http://192.168.1.100:8000" />
                                </StackPanel>
                                <Button Content="Test Connection"
                                        Command="{x:Bind ViewModel.TestConnectionCommand}" />
                                <TextBlock Text="{x:Bind ViewModel.TestConnectionStatus, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>

                    <!-- Schedule tab -->
                    <TabViewItem Header="Schedule">
                        <ScrollViewer Padding="0 12">
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Frequency" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <ComboBox SelectedIndex="{x:Bind ViewModel.EditingProfile.Schedule.FrequencyIndex, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Off" />
                                        <ComboBoxItem Content="Hourly" />
                                        <ComboBoxItem Content="Daily" />
                                        <ComboBoxItem Content="Weekly" />
                                        <ComboBoxItem Content="Custom" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Hour (0–23)" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <NumberBox Value="{x:Bind ViewModel.EditingProfile.Schedule.Hour, Mode=TwoWay}"
                                               Minimum="0" Maximum="23" SpinButtonPlacementMode="Compact" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Minute (0–59)" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <NumberBox Value="{x:Bind ViewModel.EditingProfile.Schedule.Minute, Mode=TwoWay}"
                                               Minimum="0" Maximum="59" SpinButtonPlacementMode="Compact" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Custom Interval (minutes)" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <NumberBox Value="{x:Bind ViewModel.EditingProfile.Schedule.CustomMinutes, Mode=TwoWay}"
                                               Minimum="5" Maximum="10080" SpinButtonPlacementMode="Compact" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabViewItem>

                    <!-- Exclusions tab -->
                    <TabViewItem Header="Exclusions">
                        <StackPanel Padding="0 12" Spacing="12">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{x:Bind ViewModel.NewExclude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="e.g. .DS_Store, node_modules" />
                                <Button Grid.Column="1" Content="Add"
                                        Command="{x:Bind ViewModel.AddExcludeCommand}" />
                            </Grid>

                            <ListView ItemsSource="{x:Bind ViewModel.EditingProfile.Excludes, Mode=OneWay}"
                                      SelectionMode="None"
                                      MaxHeight="260">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid>
                                            <TextBlock Text="{x:Bind}" VerticalAlignment="Center" />
                                            <Button HorizontalAlignment="Right"
                                                    Content="Remove"
                                                    CommandParameter="{x:Bind}"
                                                    Click="RemoveExclude_Click" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </TabViewItem>

                </TabView>

                <!-- CLI Preview -->
                <Expander Header="CLI Command Preview" HorizontalAlignment="Stretch">
                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                            CornerRadius="4" Padding="12">
                        <TextBlock Text="{x:Bind ViewModel.CliPreview, Mode=OneWay}"
                                   FontFamily="Consolas" FontSize="12"
                                   TextWrapping="WrapWholeWords"
                                   IsTextSelectionEnabled="True" />
                    </Border>
                </Expander>

            </StackPanel>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Column="2"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12"
                    Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolNegToVisConverter}}">
            <FontIcon Glyph="&#xEBD2;" FontSize="48"
                      Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="Select or create a backup profile"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
