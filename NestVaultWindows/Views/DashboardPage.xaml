<Page
    x:Class="NestVaultWindows.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:NestVaultWindows.Views.Controls"
    xmlns:vm="using:NestVaultWindows.ViewModels"
    Background="Transparent">

    <ScrollViewer>
        <StackPanel Padding="24 16" Spacing="20">

            <!-- Server disconnected banner -->
            <InfoBar x:Name="ServerBanner"
                     Title="Server Unreachable"
                     Message="Check your server URL and API key in Settings."
                     Severity="Error"
                     IsOpen="{x:Bind ViewModel.IsConnected, Mode=OneWay, Converter={StaticResource BoolNegateConverter}}"
                     IsClosable="False" />

            <!-- Stats cards row -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition /><ColumnDefinition />
                    <ColumnDefinition /><ColumnDefinition />
                </Grid.ColumnDefinitions>

                <controls:StatCard Grid.Column="0"
                    Title="Backups"
                    Value="{x:Bind ViewModel.Stats.TotalBackups, Mode=OneWay}"
                    Subtitle="active" />
                <controls:StatCard Grid.Column="1"
                    Title="Versions"
                    Value="{x:Bind ViewModel.Stats.TotalVersions, Mode=OneWay}"
                    Subtitle="total" />
                <controls:StatCard Grid.Column="2"
                    Title="Files"
                    Value="{x:Bind ViewModel.Stats.TotalFiles, Mode=OneWay}"
                    Subtitle="deduplicated" />
                <controls:StatCard Grid.Column="3"
                    Title="Storage"
                    Value="{x:Bind ViewModel.Stats.FormattedSize, Mode=OneWay}"
                    Subtitle="on server" />
            </Grid>

            <!-- Active backups -->
            <StackPanel Spacing="8">
                <Grid>
                    <TextBlock Text="Active Backups"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button HorizontalAlignment="Right"
                            Command="{x:Bind ViewModel.ReloadCommand}"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolNegateConverter}}"
                            Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                </Grid>

                <ProgressBar IsIndeterminate="True"
                             Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <ListView ItemsSource="{x:Bind ViewModel.Backups, Mode=OneWay}"
                              SelectionMode="None"
                              Padding="0 4">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:BackupSummaryItem">
                                <Grid Padding="12 8" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind FormattedLastVersion}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind FormattedSize}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="2"
                                               Text="{x:Bind VersionCount}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </StackPanel>

            <!-- How it works -->
            <Expander Header="How It Works" HorizontalAlignment="Stretch">
                <StackPanel Padding="8" Spacing="6">
                    <TextBlock TextWrapping="WrapWholeWords">
                        NestVault uses SHA-256 deduplication — identical file content is stored only once
                        across all backups and versions.
                    </TextBlock>
                    <TextBlock TextWrapping="WrapWholeWords">
                        Each backup run creates a new version. Files unchanged since the last version
                        are registered by hash (no re-upload). Smart Skip can detect runs with zero
                        changes and create an absorbed version in milliseconds.
                    </TextBlock>
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        Server: <Run Text="{x:Bind ViewModel.ServerVersion, Mode=OneWay}" />
                        · App: <Run Text="{x:Bind ViewModel.AppVersion}" />
                    </TextBlock>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
